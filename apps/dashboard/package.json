{
  "name": "@monoweb/dashboard",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "e2e:test": "exec playwright test",
    "e2e:test:ui": "exec playwright test --ui",
    "e2e:test:chrome": "exec playwright test --project=chromium",
    "e2e:test:firefox": "exec playwright test --project=firefox",
    "e2e:test:webkit": "exec playwright test --project=webkit",
    "e2e:test:generate": "exec playwright codegen",
    "e2e:show-report": "exec playwright show-report",
    "e2e:install": "exec playwright install"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@hookform/resolvers": "^4.1.3",
    "@mantine/hooks": "^7.17.3",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@react-router/fs-routes": "^7.4.1",
    "@react-router/node": "^7.4.1",
    "@react-router/serve": "^7.4.1",
    "@tailwindcss/vite": "^4.0.17",
    "@tanstack/react-table": "^8.21.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "isbot": "^5.1.25",
    "lucide-react": "^0.486.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.55.0",
    "react-router": "^7.4.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.17",
    "tailwindcss-animate": "^1.0.7",
    "tanstack": "^1.0.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.2",
    "@vektorprogrammet/sdk": "^0.1.1",
    "@tanstack/react-query": "^5"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@react-router/dev": "^7.4.1",
    "@tailwindcss/postcss": "^4.0.17",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.4"
  },
  "peerDependencies": {
    "react-router-dom": "^7.4.0"
  }
}
