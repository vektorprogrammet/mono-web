{
    "name": "vektorprogrammet/vektorprogrammet",
    "description": "Vektorprogrammet's website",
    "license": "proprietary",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "src/App"
        },
        "classmap": [
            "src/Kernel.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "ext-json": "*",
        "ext-openssl": "*",
        "api-platform/core": "^3.4",
        "doctrine/dbal": "^3.0",
        "doctrine/doctrine-bundle": "^2.0",
        "doctrine/doctrine-fixtures-bundle": "^3.0.2",
        "doctrine/doctrine-migrations-bundle": "^3.0",
        "doctrine/orm": "^2.5",
        "dompdf/dompdf": "^1.0",
        "excelwebzone/recaptcha-bundle": "^1.5",
        "friendsofsymfony/ckeditor-bundle": "^2.0",
        "google/apiclient": "^2.2",
        "helios-ag/fm-elfinder-bundle": "^12.0",
        "knplabs/knp-paginator-bundle": "^6.0",
        "lexik/jwt-authentication-bundle": "^3.2",
        "liip/imagine-bundle": "^2.1",
        "ramsey/uuid": "^3.7",
        "symfony/asset": "6.4.*",
        "symfony/cache": "6.4.*",
        "symfony/clock": "6.4.*",
        "symfony/config": "6.4.*",
        "symfony/console": "6.4.*",
        "symfony/css-selector": "6.4.*",
        "symfony/dependency-injection": "6.4.*",
        "symfony/doctrine-bridge": "6.4.*",
        "symfony/dom-crawler": "6.4.*",
        "symfony/dotenv": "6.4.*",
        "symfony/error-handler": "6.4.*",
        "symfony/event-dispatcher": "6.4.*",
        "symfony/expression-language": "6.4.*",
        "symfony/filesystem": "6.4.*",
        "symfony/finder": "6.4.*",
        "symfony/form": "6.4.*",
        "symfony/framework-bundle": "6.4.*",
        "symfony/http-foundation": "6.4.*",
        "symfony/http-kernel": "6.4.*",
        "symfony/lock": "^7.4",
        "symfony/mailer": "6.4.*",
        "symfony/mime": "6.4.*",
        "symfony/monolog-bundle": "^3.5",
        "symfony/options-resolver": "6.4.*",
        "symfony/password-hasher": "6.4.*",
        "symfony/process": "6.4.*",
        "symfony/property-access": "6.4.*",
        "symfony/property-info": "6.4.*",
        "symfony/psr-http-message-bridge": "6.4.*",
        "symfony/rate-limiter": "^7.2",
        "symfony/routing": "6.4.*",
        "symfony/security-bundle": "6.4.*",
        "symfony/security-core": "6.4.*",
        "symfony/security-csrf": "6.4.*",
        "symfony/security-http": "6.4.*",
        "symfony/serializer": "6.4.*",
        "symfony/stopwatch": "6.4.*",
        "symfony/string": "6.4.*",
        "symfony/translation": "6.4.*",
        "symfony/twig-bundle": "6.4.*",
        "symfony/validator": "6.4.*",
        "symfony/var-dumper": "6.4.*",
        "symfony/var-exporter": "6.4.*",
        "symfony/yaml": "6.4.*",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "ext-pdo_sqlite": "*",
        "brianium/paratest": "^6.0",
        "dama/doctrine-test-bundle": "^8.2",
        "friendsofphp/php-cs-fixer": "^3.0",
        "nelmio/cors-bundle": "^2.0",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^9.5",
        "qossmic/deptrac": "^2",
        "rector/rector": "^2.3",
        "symfony/browser-kit": "6.4.*",
        "symfony/debug-bundle": "6.4.*",
        "symfony/phpunit-bridge": "6.4.*",
        "symfony/web-profiler-bundle": "6.4.*"
    },
    "scripts": {
        "pre-autoload-dump": "Google\\Task\\Composer::cleanup",
        "test": "bash -c 'start_time=$(date +%s) && php -d memory_limit=256M bin/phpunit -c phpunit.xml.dist --log-junit var/test-results.xml; exit_code=$?; end_time=$(date +%s); echo \"Wall time: $((end_time - start_time))s\"; exit $exit_code'",
        "test:parallel": "bash -c 'start_time=$(date +%s) && php -d memory_limit=256M bin/paratest -p4 --runner=WrapperRunner -c phpunit.xml.dist --log-junit var/test-results-parallel.xml; exit_code=$?; end_time=$(date +%s); echo \"Wall time: $((end_time - start_time))s\"; exit $exit_code'",
        "test:coverage": "bash -c 'start_time=$(date +%s) && phpdbg -qrr -d memory_limit=1G bin/phpunit -c phpunit.xml.dist --coverage-html var/coverage; exit_code=$?; end_time=$(date +%s); echo \"Wall time: $((end_time - start_time))s\"; exit $exit_code'",
        "test:unit": "@php bin/phpunit --testsuite=unit",
        "test:controller": "@php bin/phpunit --testsuite=controller",
        "test:availability": "@php bin/phpunit --testsuite=availability",
        "syntax": "parallel-lint src/ tests/ --exclude vendor",
        "lint": "bin/php-cs-fixer fix --dry-run --diff",
        "fix": "bin/php-cs-fixer fix",
        "analyse": "bin/phpstan analyse --memory-limit=256M",
        "deptrac": "bin/deptrac analyse --config-file=deptrac.yaml --no-progress"
    },
    "config": {
        "bin-dir": "bin",
        "component-dir": "public/assets",
        "audit": {
            "block-insecure": false
        },
        "allow-plugins": {
            "symfony/flex": true
        },
        "sort-packages": true
    },
    "extra": {
        "google/apiclient-services": [
            "Drive",
            "Directory",
            "Gmail"
        ],
        "symfony": {
            "allow-contrib": false,
            "require": "6.4.*"
        }
    }
}
