{
  "name": "@monoweb/server",
  "private": true,
  "scripts": {
    "build": "echo 'Run: composer dump-autoload --optimize'",
    "build:prod": "vite build --mode production",
    "dev": "php -S 0.0.0.0:8000 -t public",
    "test": "echo 'Run: php -d memory_limit=512M bin/phpunit'",
    "lint": "echo 'Run: composer lint (requires vendor/)'",
    "fix": "echo 'Run: composer fix (requires vendor/)'",
    "api:spec": "php bin/console api:openapi:export --output=../../packages/sdk/openapi.json"
  },
  "dependencies": {
    "@coreui/coreui": "2.0.18",
    "@fortawesome/fontawesome-free": "5.4.1",
    "bootstrap": "^4.5.2",
    "ckeditor": "4.5.10",
    "cropperjs": "1.4.1",
    "dropzone": "4.3.0",
    "jquery": "^3.5.1",
    "moment": "2.22.2",
    "popper.js": "1.14.4"
  },
  "devDependencies": {
    "@vitejs/plugin-legacy": "^5.4.3",
    "autoprefixer": "^10.4.24",
    "sass": "^1.85.0",
    "terser": "^5.46.0",
    "vite": "^5.4.16",
    "vite-plugin-static-copy": "^2.3.0"
  }
}
