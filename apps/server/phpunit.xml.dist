<?xml version="1.0" encoding="UTF-8"?>

<!-- http://phpunit.de/manual/4.1/en/appendixes.configuration.html -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="http://schema.phpunit.de/4.1/phpunit.xsd"
         backupGlobals="false"
         colors="true"
         bootstrap="tests/bootstrap.php"
>
    <php>
        <env name="APP_ENV" value="test" />
        <env name="APP_DEBUG" value="1" />
        <env name="KERNEL_CLASS" value="Kernel" />
        <env name="SYMFONY_DEPRECATIONS_HELPER" value="disabled" />
    </php>
    <testsuites>
        <testsuite name="unit">
            <directory>tests/AppBundle/Entity</directory>
            <directory>tests/AppBundle/Extension</directory>
            <directory>tests/AppBundle/Service</directory>
            <directory>tests/AppBundle/Sms</directory>
            <directory>tests/AppBundle/Type</directory>
            <directory>tests/AppBundle/Util</directory>
        </testsuite>
        <testsuite name="controller">
            <directory>tests/AppBundle/Controller</directory>
        </testsuite>
        <testsuite name="availability">
            <directory>tests/AppBundle/Availability</directory>
        </testsuite>
        <testsuite name="api">
            <directory>tests/AppBundle/Api</directory>
        </testsuite>
    </testsuites>
    <coverage>
        <include>
            <directory suffix=".php">src</directory>
        </include>
        <exclude>
            <directory>vendor</directory>
            <directory>var</directory>
            <directory>tests</directory>

        </exclude>
    </coverage>
    <extensions>
        <extension class="DAMA\DoctrineTestBundle\PHPUnit\PHPUnitExtension"/>
    </extensions>
</phpunit>
