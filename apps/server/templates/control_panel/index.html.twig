{% extends 'adminBase.html.twig' %}
{% block title %}Kontrollpanel{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset_with_version('css/pages/admin/home.css') }}">
{% endblock %}

{% block default_breadcrumb %}
    <li class="breadcrumb-item">
        <a href="{{ path('home') }}">Forsiden</a>
    </li>
    <li class="breadcrumb-item active">
        Kontrollpanel
    </li>
{% endblock %}


{% block body %}
    <div class="control-panel">
        <div class="sbs my-5">
            {{ render(controller('App\\Controller\\ControlPanelController::showSBSAction')) }}
        </div>

        <div class="row">
            {% if admissionPeriod and admissionPeriod.hasActiveAdmission %}
                {{ render(controller("App\\Controller\\WidgetController::applicationGraphAction")) }}
            {% endif %}

            {{ render(controller("App\\Controller\\WidgetController::availableSurveysAction")) }}
            {{ render(controller("App\\Controller\\WidgetController::interviewsAction")) }}
            {{ render(controller("App\\Controller\\WidgetController::receiptsAction")) }}
            {{ render(controller("App\\Controller\\WidgetController::changelogAction")) }}
            {{ render(controller("App\\Controller\\WidgetController::feedbackAction",{'request': app.request})) }}

            {% if not admissionPeriod or not admissionPeriod.hasActiveAdmission %}
                {{ render(controller("App\\Controller\\WidgetController::applicationGraphAction")) }}
            {% endif %}
        </div>
    </div>
{% endblock %}
