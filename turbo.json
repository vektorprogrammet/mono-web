{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "test": {},
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "api:spec": {
      "cache": false
    },
    "generate": {
      "dependsOn": ["^api:spec"],
      "inputs": ["openapi.json"],
      "outputs": ["generated/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
  }
}
